; Array of piece graphics. Each byte represents one row of 8 pixels.
font_data LABEL BYTE

; Pawn (replaces ASCII 01h)
DB 00000000b, 00000000b, 00000000b, 00011000b
DB 00111100b, 00111100b, 00011000b, 00011000b
DB 00011000b, 00111100b, 01111110b, 11111111b
DB 11111111b, 00000000b, 00000000b, 00000000b

; Knight (replaces ASCII 02h)
DB 00000000b, 00000000b, 00001100b, 00011110b
DB 00111110b, 01111110b, 01110110b, 01111110b
DB 00111100b, 00011100b, 00111110b, 01111111b
DB 11111111b, 00000000b, 00000000b, 00000000b

; Bishop (replaces ASCII 03h)
DB 00000000b, 00011000b, 00011000b, 00111100b
DB 00011000b, 00011000b, 00111100b, 01111110b
DB 01100110b, 01111110b, 00111100b, 01111110b
DB 11111111b, 00000000b, 00000000b, 00000000b

; Rook (replaces ASCII 04h)
DB 00000000b, 00000000b, 01010101b, 01111110b
DB 01111110b, 00111100b, 00111100b, 00111100b
DB 00111100b, 00111100b, 01111110b, 01111110b
DB 11111111b, 00000000b, 00000000b, 00000000b

; Queen (replaces ASCII 05h)
DB 00000000b, 01011010b, 01111110b, 00111100b
DB 00011000b, 00111100b, 01111110b, 01111110b
DB 00111100b, 00111100b, 01111110b, 11111111b
DB 11111111b, 00000000b, 00000000b, 00000000b

; King (replaces ASCII 06h)
DB 00000000b, 00010000b, 00010000b, 00111000b
DB 01111100b, 10111010b, 11111110b, 11111110b
DB 11111110b, 11111110b, 01111100b, 00111000b
DB 00111000b, 01111100b, 11111110b, 00000000b